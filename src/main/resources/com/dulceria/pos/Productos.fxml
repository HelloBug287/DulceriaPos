<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1080.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.dulceria.pos.controlador.ProductosController">
    <children>
        <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>

                <Label text="📦 Gestión de Inventario" textFill="#555555">
                    <font><Font name="System Bold" size="24.0" /></font>
                </Label>

                <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10;">
                    <effect>
                        <DropShadow color="#0000001a" height="10.0" radius="4.5" width="10.0" />
                    </effect>
                    <padding>
                        <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                    </padding>
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label text="Buscar Producto:" textFill="#888888" />
                                <TextField fx:id="txtBuscar" prefWidth="250.0" promptText="🔍 Nombre o Código..." />
                            </children>
                        </VBox>

                        <VBox spacing="5.0">
                            <children>
                                <Label text="Filtrar por:" textFill="#888888" />
                                <ComboBox fx:id="comboFiltroCategoria" prefWidth="180.0" promptText="Todas las Categorías" />
                            </children>
                        </VBox>

                        <Pane HBox.hgrow="ALWAYS" /> <Button fx:id="btnNuevo" mnemonicParsing="false" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-cursor: hand;" text="+ Nuevo">
                        <font><Font name="System Bold" size="14.0" /></font>
                    </Button>

                        <Button fx:id="btnEditar" disable="true" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-cursor: hand;" text="Editar">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>

                        <Button fx:id="btnEliminar" disable="true" mnemonicParsing="false" prefHeight="40.0" prefWidth="100.0" style="-fx-background-color: #c0392b; -fx-text-fill: white; -fx-cursor: hand;" text="Eliminar">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Button>
                    </children>
                </HBox>

                <TableView fx:id="tablaProductos" style="-fx-background-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                        <TableColumn fx:id="colCodigo" prefWidth="120.0" text="C. Barras" />
                        <TableColumn fx:id="colNombre" prefWidth="250.0" text="Nombre Producto" />
                        <TableColumn fx:id="colCategoria" prefWidth="120.0" text="Categoría" />
                        <TableColumn fx:id="colMarca" prefWidth="120.0" text="Marca" />
                        <TableColumn fx:id="colStock" prefWidth="100.0" style="-fx-alignment: CENTER;" text="Stock" />
                        <TableColumn fx:id="colUnidad" prefWidth="80.0" style="-fx-alignment: CENTER;" text="Unidad" />
                        <TableColumn fx:id="colPrecio" prefWidth="100.0" style="-fx-alignment: CENTER-RIGHT; -fx-font-weight: bold;" text="Precio" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <children>
                        <Label text="Total de Productos:" textFill="#888888" />
                        <Label fx:id="lblTotalProductos" text="0" textFill="#555555">
                            <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                    </children>
                </HBox>

            </children>
        </VBox>
    </children>
</AnchorPane>
